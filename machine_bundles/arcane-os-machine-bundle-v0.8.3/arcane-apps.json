{
  "schemaVersion": 1,
  "workspaceRoot": "../..",
  "sharedPayload": [
    {
      "source": "arcane",
      "destination": "arcane",
      "include": [
        "components",
        "css",
        "entities",
        "img",
        "models",
        "modules"
      ]
    },
    {
      "source": "node_modules/strong-type",
      "destination": "node_modules/strong-type",
      "include": [
        "index.js",
        "licence",
        "package.json"
      ]
    }
  ],
  "apps": {
    "files": {
      "displayName": "Files",
      "description": "A private file workspace for documents, downloads, pictures, uploads, and exports.",
      "icon": "img/icon.png",
      "order": 30,
      "type": "app",
      "source": "apps/files",
      "entry": "index.html",
      "capabilities": [
        "preferences.read",
        "storage.read",
        "storage.write"
      ],
      "security": {
        "connectOrigins": [],
        "mediaOrigins": []
      },
      "include": [
        "files.css",
        "img/icon.png",
        "index.html",
        "manifest.json",
        "modules"
      ]
    },
    "precrisis": {
      "displayName": "PreCrisis AI",
      "description": "Clinical decision support, structured notes, and operational dashboards for earlier intervention.",
      "icon": "img/192.png",
      "order": 20,
      "type": "app",
      "source": "apps/precrisis",
      "entry": "index.html",
      "capabilities": [
        "ai.inference",
        "ai.models.read",
        "diagnostics.read",
        "identity.read",
        "installation.read",
        "media.microphone",
        "network.status.read",
        "requirements.read",
        "storage.read",
        "storage.write",
        "system.metrics.read",
        "system.read"
      ],
      "security": {
        "connectOrigins": [
          "http://127.0.0.1:8011",
          "http://127.0.0.1:11434",
          "https://api.openai.com"
        ],
        "mediaOrigins": [
          "https://cdn.openai.com"
        ]
      },
      "include": [
        "admin.html",
        "chat.html",
        "components",
        "dashboard-clinical.html",
        "dashboard-leadership.html",
        "dashboard.html",
        "data.html",
        "entities",
        "export.html",
        "img/1024.png",
        "img/192.png",
        "img/256.png",
        "img/512.png",
        "img/favicon.png",
        "img/icon-16.ico",
        "import-many.html",
        "import.html",
        "index.html",
        "journal.html",
        "manifest.json",
        "modules",
        "prev.html",
        "service-worker.js",
        "soc.html"
      ]
    },
    "boss": {
      "displayName": "BOSS",
      "description": "A private workspace for grounded business research, document libraries, and assisted analysis.",
      "icon": "img/boss-libraries-logo-stacked.png",
      "order": 10,
      "type": "app",
      "source": "apps/boss",
      "entry": "chat.html",
      "capabilities": [
        "ai.inference",
        "ai.models.read",
        "diagnostics.read",
        "identity.read",
        "installation.read",
        "network.status.read",
        "requirements.read",
        "storage.read",
        "storage.write",
        "system.metrics.read",
        "system.read"
      ],
      "security": {
        "connectOrigins": [
          "http://127.0.0.1:8011",
          "http://127.0.0.1:11434",
          "https://api.openai.com"
        ],
        "mediaOrigins": [
          "https://cdn.openai.com"
        ]
      },
      "documentCatalog": {
        "policy": "empty-unpublished",
        "destination": "documents",
        "manifest": "document-manifest.json"
      },
      "include": [
        "Modelfile",
        "admin.html",
        "boss-library.js",
        "boss.css",
        "chat.html",
        "components",
        "export.html",
        "img",
        "import.html",
        "library-setup.html",
        "library.html",
        "manifest.json",
        "prompts"
      ]
    },
    "terminal": {
      "displayName": "Arcane Terminal",
      "description": "Native shell sessions with Arcane APIs, registered system tools, themes, search, and keyboard-first controls.",
      "icon": "img/arcane-terminal.png",
      "order": 50,
      "type": "app",
      "source": "apps/terminal",
      "entry": "index.html",
      "capabilities": [
        "ai.models.read",
        "applications.launch",
        "applications.read",
        "diagnostics.read",
        "identity.read",
        "network.status.read",
        "preferences.read",
        "preferences.write",
        "system.metrics.read",
        "system.read",
        "terminal.execute"
