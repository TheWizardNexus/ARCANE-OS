        "mediaOrigins": []
      },
      "include": [
        "img/icon.png",
        "index.html",
        "mail.css",
        "manifest.json",
        "modules"
      ]
    },
    "messages": {
      "displayName": "Arcane Messages",
      "description": "A unified, channel-labeled inbox for SMS, RCS, WhatsApp, and compatible messaging services.",
      "icon": "img/icon.png",
      "order": 70,
      "type": "app",
      "source": "apps/messages",
      "entry": "index.html",
      "capabilities": [
        "network.status.read",
        "preferences.read",
        "preferences.write"
      ],
      "security": {
        "connectOrigins": [
          "http://127.0.0.1:8020"
        ],
        "mediaOrigins": []
      },
      "include": [
        "img/icon.png",
        "index.html",
        "manifest.json",
        "messages.css",
        "modules"
      ]
    },
    "settings": {
      "displayName": "Settings",
      "description": "Shared appearance, accessibility, device, and local AI brain controls.",
      "icon": "img/icon.png",
      "order": 40,
      "type": "app",
      "source": "apps/settings",
      "entry": "index.html",
      "capabilities": [
        "ai.inference",
        "ai.models.manage",
        "ai.models.read",
        "ai.settings.manage",
        "identity.read",
        "network.status.read",
        "preferences.read",
        "preferences.write",
        "system.read"
      ],
      "security": {
        "connectOrigins": [],
        "mediaOrigins": []
      },
      "include": [
        "ai-settings.css",
        "img/icon.png",
        "index.html",
        "manifest.json",
        "modules",
        "provider-settings.css",
        "settings.css"
      ]
