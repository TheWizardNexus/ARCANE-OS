      "security": {
        "connectOrigins": [],
        "mediaOrigins": []
      },
      "include": [
        "img/arcane-terminal.png",
        "index.html",
        "manifest.json",
        "modules",
        "terminal.css"
      ]
    },
    "mail": {
      "displayName": "Arcane Mail",
