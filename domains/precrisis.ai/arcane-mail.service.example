[Unit]
Description=Arcane loopback mail gateway
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=arcane-mail
Group=arcane-mail
WorkingDirectory=/opt/arcane
EnvironmentFile=/etc/arcane/mail-gateway.env
ExecStart=/usr/bin/node /opt/arcane/arcane/server/MailGateway.mjs
Restart=on-failure
RestartSec=5s
TimeoutStopSec=450s
UMask=0077

NoNewPrivileges=true
PrivateDevices=true
PrivateTmp=true
ProtectControlGroups=true
ProtectHome=true
ProtectKernelModules=true
ProtectKernelTunables=true
ProtectSystem=strict
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6
RestrictRealtime=true
RestrictSUIDSGID=true

[Install]
WantedBy=multi-user.target
