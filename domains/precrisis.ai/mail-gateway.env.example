# Copy to a root-owned deployment secret file such as
# /etc/arcane/mail-gateway.env and set mode 0600. Never commit real values.

MAIL_HOST=127.0.0.1
MAIL_PORT=8025
MAIL_PATH=/v1/mail
MAIL_HEALTH_PATH=/healthz
MAIL_READY_PATH=/readyz

# These values authorize only the trusted reverse proxy. The browser never
# receives either secret. The matching Caddy environment values must contain
# the same per-app secrets.
MAIL_APP_KEYS='{"precrisis":"replace-with-a-random-secret-at-least-32-characters","warrior-spirit":"replace-with-a-different-random-secret-at-least-32-characters"}'
MAIL_ALLOWED_ORIGINS=https://app.precrisis.ai,https://warrior-spirit.precrisis.ai

MAIL_SMTP_HOST=smtp.example.com
MAIL_SMTP_PORT=465
MAIL_SMTP_SECURE=true
MAIL_SMTP_USER=arcane-mail@example.com
MAIL_SMTP_PASS=replace-with-an-smtp-app-password

# These defaults form one tested timeout chain with the example Caddyfile,
# browser client, and systemd unit. The gateway fails startup if overrides
# would outlive those outer deadlines.
MAIL_REQUEST_TIMEOUT_MS=120000
MAIL_SMTP_CONNECTION_TIMEOUT_MS=10000
MAIL_SMTP_GREETING_TIMEOUT_MS=10000
MAIL_SMTP_SOCKET_TIMEOUT_MS=120000
MAIL_SMTP_ATTEMPT_TIMEOUT_MS=150000
MAIL_SMTP_RETRY_ATTEMPTS=2
MAIL_SMTP_RETRY_BASE_MS=250

# Routing is server-owned. Browser payloads cannot select a From address.
MAIL_FROM_ERROR=arcane-errors@example.com
MAIL_FROM_REPORT=arcane-reports@example.com
MAIL_FROM_CRISIS_DETECTED=arcane-crisis@example.com
MAIL_ERROR_RECIPIENTS=operations@example.com

# Keep false unless the gateway port is unreachable except through one trusted
# proxy that overwrites X-Forwarded-For. The default safely rate-limits the
# proxy as one client.
MAIL_TRUST_PROXY=false
