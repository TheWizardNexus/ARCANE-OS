{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://arcane.local/schemas/investigator/investigative-analysis.schema.json",
  "title":"Arcane Investigator source-cited analysis index",
  "type":"object",
  "required":["schemaVersion","caseId","posture","coverage","filings","findings","crossReferences","timeline","orders","motives","map"],
  "properties":{
    "schemaVersion":{"const":1},
    "caseId":{"type":"string","minLength":1,"maxLength":80},
    "generatedAt":{"type":"string","format":"date-time"},
    "posture":{"type":"object","required":["label","statement","prohibitedInference"]},
    "coverage":{
      "type":"object",
      "required":["filingsScanned","filingsRepresented","crossRecordPairsScreened","curatedCrossReferences"],
      "properties":{
        "filingsScanned":{"type":"integer","minimum":0},
        "filingsRepresented":{"type":"integer","minimum":0},
        "crossRecordPairsScreened":{"type":"integer","minimum":0},
        "curatedCrossReferences":{"type":"integer","minimum":0}
      }
    },
    "filings":{"type":"array","maxItems":10000,"items":{"$ref":"#/$defs/filingAudit"}},
    "findings":{"type":"array","maxItems":50000,"items":{"$ref":"#/$defs/finding"}},
    "crossReferences":{"type":"array","maxItems":10000,"items":{"$ref":"#/$defs/comparison"}},
    "timeline":{"type":"array","maxItems":50000,"items":{"$ref":"#/$defs/timelineEvent"}},
    "orders":{"type":"array","maxItems":10000,"items":{"$ref":"#/$defs/order"}},
    "motives":{"type":"array","maxItems":10000,"items":{"$ref":"#/$defs/motive"}},
    "map":{"type":"object","required":["lanes","nodes","edges"]}
  },
  "$defs":{
    "source":{
      "type":"object",
      "required":["recordId","filename","pdfPath","markdownPath","lineStart","lineEnd","excerpt","sourceTier"],
      "properties":{
        "recordId":{"type":"string","pattern":"^F[0-9]{4}$"},
        "page":{"type":["integer","null"],"minimum":1},
        "lineStart":{"type":"integer","minimum":1},
        "lineEnd":{"type":"integer","minimum":1},
        "excerpt":{"type":"string","minLength":1,"maxLength":10000}
      }
    },
    "filingAudit":{
      "type":"object",
      "required":["recordId","filedDate","filingParty","title","auditStatus","findingIds","findingCount"],
      "properties":{"recordId":{"type":"string","pattern":"^F[0-9]{4}$"},"findingIds":{"type":"array","items":{"type":"string"}},"findingCount":{"type":"integer","minimum":0}}
    },
    "finding":{
      "type":"object",
      "required":["id","recordId","label","kind","status","allegedActor","allegedActorLabel","assessment","elementsToVerify","limitations","sources"],
      "properties":{"id":{"type":"string","pattern":"^[LC]-F[0-9]{4}-[0-9]{3}$"},"recordId":{"type":"string","pattern":"^F[0-9]{4}$"},"sources":{"type":"array","minItems":1,"maxItems":40,"items":{"$ref":"#/$defs/source"}}}
    },
    "comparison":{
      "type":"object",
      "required":["id","label","whyItMayConflict","alternativeExplanation","resolveWith","sources"],
      "properties":{"id":{"type":"string","pattern":"^X[0-9]{4}$"},"sources":{"type":"array","minItems":1,"maxItems":40,"items":{"$ref":"#/$defs/source"}}}
    },
    "timelineEvent":{
      "type":"object",
      "required":["id","date","category","title","sources"],
      "properties":{"date":{"type":"string","pattern":"^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},"sources":{"type":"array","maxItems":40,"items":{"$ref":"#/$defs/source"}}}
    },
    "order":{
      "type":"object",
      "required":["id","date","title","status","obligation","assessment","sources"],
      "properties":{"status":{"enum":["satisfied","partial","candidate-conflict","disputed","superseded","deadline-pending","outcome-not-in-record"]},"sources":{"type":"array","minItems":1,"maxItems":40,"items":{"$ref":"#/$defs/source"}}}
    },
    "motive":{
      "type":"object",
      "required":["id","actor","actorLabel","hypothesis","status","summary","contraryConsiderations","sources"],
      "properties":{"status":{"type":"string","pattern":"hypothesis"},"contraryConsiderations":{"type":"array","minItems":1},"sources":{"type":"array","minItems":1,"maxItems":40,"items":{"$ref":"#/$defs/source"}}}
    }
  }
}
