# Vendor only approved first-party modules authored by RIAEvangelist.
**/node_modules/
!/node_modules/
/node_modules/*
!/node_modules/strong-type/
!/node_modules/strong-type/**
!dist/*/node_modules/
dist/*/node_modules/*
!dist/*/node_modules/strong-type/
!dist/*/node_modules/strong-type/**
.pnpm-store/
/pnpm-lock.yaml
machine_bundles/**/dist/
local/
tmp/
apps/boss/business docs/
apps/boss/documents/
