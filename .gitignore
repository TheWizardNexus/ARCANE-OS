# Git LFS installs these local lifecycle hooks into the configured hooks path.
.githooks/post-checkout
.githooks/post-commit
.githooks/post-merge

# Signing keys stay in the Windows certificate store or a hardware provider.
*.pfx
*.p12
*.pem
*.key
*.pvk
*.snk

